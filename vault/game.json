  {
    "name": "Super Smash Flash",
    "windows": {
      "scoop": "https://gist.githubusercontent.com/Davido264/42b2e11fb5f5d246e0899c8f5dc1f4bc/raw/e4b8cc57dcf6d0f592cf699d101a1d393d954156/ssf2.json",
      "notwhen": "exit 0"
    },
    "linux": {
      "before": "sudo mkdir /usr/share/ssf2 && cd /usr/share/ssf2",
      "sh": "curl -sSL https://cdn.supersmashflash.com/ssf2/downloads/14ac5596/SSF2Betaubuntu.v1.3.1.2.tar | tar -xvf - && printf '#!/usr/bin/sh\\ncd /usr/share/ssf2 && ./SSF2 &\\n' | sudo tee /usr/bin/SSF2 && sudo chmod +x /usr/bin/SSF2",
      "after": "sudo chmod +x trust-ssf2.sh && ./trust-ssf2.sh && cd ~",
      "notwhen": "which SSF2"
    }
  }
]
