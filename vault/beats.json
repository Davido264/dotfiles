      "notwhen": "exit 0"
    },
    "linux": null
  },
  {
    "name": "labs-lm",
    "windows": {
      "scoop": "https://gist.githubusercontent.com/Davido264/a277db84cb1914188f110255ebf2561c/raw/d0dad6536d50e3d267f55b275224a1b8e13c885e/labs-lm.json",
      "notwhen": "exit 0"
    },
    "linux": null
  },
