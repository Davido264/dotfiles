{{ if (eq .chezmoi.os "linux") -}}
#!/bin/sh

# registry hash: {{ include (joinPath .chezmoi.workingTree "vault" "dev.json") | sha256sum }}

# before
{{ joinPath .chezmoi.workingTree "vault" "dev.json" | include | fromJson | jq `.[] | select(.__before__) | .__before__ | select(.linux) | .linux.[]` | join "\n"}}

{{ if (and (hasKey .chezmoi.osRelease "idLike") (eq .chezmoi.osRelease.idLike "ubuntu debian")) -}}
{{ joinPath .chezmoi.workingTree "vault" "dev.json" | include | fromJson | jq `.[] | select(.__before__) | .__before__ | select(.ubuntu) | .ubuntu.[]` | join "\n"}}
{{ end -}}

{{ if (eq .chezmoi.osRelease.id "fedora") -}}
{{ joinPath .chezmoi.workingTree "vault" "dev.json" | include | fromJson | jq `.[] | select(.__before__) | .__before__ | select(.fedora) | .fedora.[]` | join "\n"}}
