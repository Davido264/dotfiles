# registry hash: {{ include (joinPath .chezmoi.workingTree "vault" "util.json") | sha256sum }}

# before
{{ joinPath .chezmoi.workingTree "vault" "util.json" | include | fromJson | jq `.[] | select(.__before__) | .__before__ | select(.linux) | .linux.[]` | join "\n"}}

{{ if (eq .chezmoi.osRelease.idLike "ubuntu debian") -}}
{{ joinPath .chezmoi.workingTree "vault" "util.json" | include | fromJson | jq `.[] | select(.__before__) | .__before__ | select(.ubuntu) | .ubuntu.[]` | join "\n"}}
