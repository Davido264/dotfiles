{{ if (eq .chezmoi.osRelease.idLike "fedora") -}}
{{ joinPath .chezmoi.workingTree "vault" "util.json" | include | fromJson | jq `.[] | select(.__before__) | .__before__ | select(.fedora) | .fedora.[]` | join "\n"}}
{{ end -}}


# exec
{{ joinPath .chezmoi.workingTree "vault" "util.json" | include | fromJson | jq `.[] | select(.linux.flatpak) | "echo '====[ \(.name) ]====' \n\(.linux.notwhen // "flatpak info \(.linux.flatpak) 2> /dev/null") || (_(){ \(.linux.before // "true") && flatpak install -y flathub \(.linux.flatpak) && \(.linux.after // "true"); };_)"` | join "\n" }}
{{ joinPath .chezmoi.workingTree "vault" "util.json" | include | fromJson | jq `.[] | select(.linux.sh) | "echo '====[ \(.name) ]====' \n\(.linux.notwhen // "false") || (_(){ \(.linux.before // "true") && (\(.linux.sh)) && \(.linux.after // "true"); };_)"` | join "\n" }}

{{ if (eq .chezmoi.osRelease.idLike "ubuntu debian") -}}
{{ joinPath .chezmoi.workingTree "vault" "util.json" | include | fromJson | jq `.[] | select(.ubuntu.apt) | "echo '====[ \(.name) ]====' \n\(.ubuntu.notwhen // "which \(.ubuntu.apt)") || (_(){ \(.ubuntu.before // "true") && sudo apt install -y \(.ubuntu.apt) && \(.ubuntu.after // "true"); };_)\n"` | join "\n" }}
{{ joinPath .chezmoi.workingTree "vault" "util.json" | include | fromJson | jq `.[] | select(.ubuntu.flatpak) | "echo '====[ \(.name) ]====' \n\(.ubuntu.notwhen // "flatpak info \(.ubuntu.flatpak) 2> /dev/null") || (_(){ \(.ubuntu.before // "true") && flatpak install -y flathub \(.ubuntu.flatpak) && \(.ubuntu.after // "true"); };_)"` | join "\n" }}
{{ joinPath .chezmoi.workingTree "vault" "util.json" | include | fromJson | jq `.[] | select(.ubuntu.sh) | "echo '====[ \(.name) ]====' \n\(.ubuntu.notwhen // "false") || (_(){ \(.ubuntu.before // "true") && (\(.ubuntu.sh)) && \(.ubuntu.after // "true"); };_)"` | join "\n" }}
{{ end -}}

{{ if (eq .chezmoi.osRelease.idLike "fedora") -}}
{{ joinPath .chezmoi.workingTree "vault" "util.json" | include | fromJson | jq `.[] | select(.fedora.dnf) | "echo '====[ \(.name) ]====' \n\(.fedora.notwhen // "which \(.fedora.dnf)") || (_(){ \(.fedora.before // "true") && sudo dnf install -y \(.fedora.dnf) && \(.fedora.after // "true"); };_)\n"` | join "\n" }}
{{ joinPath .chezmoi.workingTree "vault" "util.json" | include | fromJson | jq `.[] | select(.fedora.flatpak) | "echo '====[ \(.name) ]====' \n\(.fedora.notwhen // "flatpak info \(.fedora.flatpak) 2> /dev/null") || (_(){ \(.fedora.before // "true") && flatpak install -y flathub \(.fedora.flatpak) && \(.fedora.after // "true"); };_)"` | join "\n" }}
{{ joinPath .chezmoi.workingTree "vault" "util.json" | include | fromJson | jq `.[] | select(.fedora.sh) | "echo '====[ \(.name) ]====' \n\(.fedora.notwhen // "false") || (_(){ \(.fedora.before // "true") && (\(.fedora.sh)) && \(.fedora.after // "true"); };_)"` | join "\n" }}
{{ end -}}


