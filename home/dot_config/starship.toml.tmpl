"$schema" = 'https://starship.rs/config-schema.json'

# Inserts a blank line between shell prompts
add_newline = false

scan_timeout = 50
command_timeout = 800

format = '[(\($docker_context$conda$container$python\) )](bold white)[($username$hostname@)](bold yellow)$all'

[line_break]
disabled = true

[character]
success_symbol = '[вһң](bold green)'
error_symbol = '[вң—](bold red)'
vimcmd_symbol = '[V](bold green)'

[username]
format = '[$user]($style)'
style_user = "bold white"
show_always = false
disabled = false

[hostname]
format = '[$ssh_symbol$hostname]($style)'
style = "bold white"
ssh_symbol = "о®© "
ssh_only = true
disabled = false

[directory]
truncation_length = 1
truncation_symbol = ''
read_only = " о©ө"
disabled = false

[git_branch]
format = '[$symbol:\($branch\)]($style) '
symbol = "git"
disabled = false

